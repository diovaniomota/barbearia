#!/bin/sh
# Copie para run-billing.sh, preencha os valores e dê: chmod +x run-billing.sh
# O cron executa este arquivo (ele carrega as variáveis e roda o script).

export SUPABASE_URL="https://uebvtbgvsyzbyzdilren.supabase.co"
